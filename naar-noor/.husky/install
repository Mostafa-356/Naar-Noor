#!/bin/sh
# Husky install hook - runs npm install on fresh clone
# Location: naar-noor/.husky/install
# Purpose: Ensure dependencies are installed after fresh clone
# Triggers: After git clone or git checkout with package.json changes

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║             📦 POST-CLONE DEPENDENCY INSTALLATION            ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

# Check if npm is available
if ! command -v npm &> /dev/null; then
  echo "❌ ERROR: npm is not installed or not in PATH"
  echo ""
  echo "Please install Node.js and npm to install dependencies"
  exit 1
fi

# Check if package.json exists
if [ ! -f "package.json" ]; then
  echo "⚠️  WARNING: package.json not found in current directory"
  echo "Skipping npm install"
  exit 0
fi

# Run npm install
echo "📥 Installing dependencies with: npm install"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

npm install
INSTALL_RESULT=$?

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ $INSTALL_RESULT -eq 0 ]; then
  echo ""
  echo "✅ SUCCESS: Dependencies installed successfully"
  echo "✅ Husky hooks are now active"
  echo ""
  exit 0
else
  echo ""
  echo "❌ FAILURE: npm install failed"
  echo ""
  echo "Please run manually: npm install"
  echo ""
  exit 1
fi
