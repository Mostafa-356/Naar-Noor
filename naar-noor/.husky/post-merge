#!/bin/sh
# Husky post-merge hook - updates dependencies if package.json changes
# Location: naar-noor/.husky/post-merge
# Purpose: Ensure dependencies stay in sync after pulling changes
# Triggers: After git merge or git pull

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║          🔄 POST-MERGE DEPENDENCY UPDATE CHECK               ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

# Check if npm is available
if ! command -v npm &> /dev/null; then
  echo "⚠️  WARNING: npm is not installed or not in PATH"
  echo "Skipping dependency update check"
  exit 0
fi

# Check if package.json exists
if [ ! -f "package.json" ]; then
  echo "⚠️  WARNING: package.json not found in current directory"
  echo "Skipping dependency update check"
  exit 0
fi

# Check if package-lock.json or yarn.lock changed
# Exit code 0 if changed, 1 if not
git diff --quiet HEAD@{1} -- package-lock.json package.json yarn.lock 2>/dev/null

if [ $? -ne 0 ]; then
  # package.json or lock file has changed
  echo "📝 Detected changes to package.json or lock file"
  echo "📥 Updating dependencies with: npm install"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  
  npm install
  INSTALL_RESULT=$?
  
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  
  if [ $INSTALL_RESULT -eq 0 ]; then
    echo ""
    echo "✅ SUCCESS: Dependencies updated successfully"
    echo "✅ Your repository is in sync"
    echo ""
    exit 0
  else
    echo ""
    echo "❌ FAILURE: npm install failed"
    echo ""
    echo "Run manually to fix: npm install"
    echo ""
    exit 1
  fi
else
  # No changes to dependencies
  echo "✅ No changes to dependencies detected"
  echo "✅ Dependencies are already in sync"
  echo ""
  exit 0
fi
