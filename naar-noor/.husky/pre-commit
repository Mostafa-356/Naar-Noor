#!/bin/sh
# Husky pre-commit hook - runs frontend tests before allowing commits
# Location: naar-noor/.husky/pre-commit
# Purpose: Validate frontend code quality by running tests before commits
# Scope: Frontend (naar-noor) tests only

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║            🧪 FRONTEND PRE-COMMIT TEST VALIDATION            ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

EXIT_CODE=0

# Check if npm is available
if ! command -v npm &> /dev/null; then
  echo "❌ ERROR: npm is not installed or not in PATH"
  echo ""
  echo "Please install Node.js and npm to run tests"
  exit 1
fi

# Run frontend tests
echo "📱 Running frontend tests with: npm test"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

npm test
TEST_RESULT=$?

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ $TEST_RESULT -eq 0 ]; then
  echo ""
  echo "✅ SUCCESS: All frontend tests passed"
  echo "✅ Your commit is proceeding..."
  echo ""
  exit 0
else
  echo ""
  echo "❌ FAILURE: Frontend tests failed"
  echo ""
  echo "The commit has been blocked. Please:"
  echo ""
  echo "  1️⃣  Review the test failures above"
  echo "  2️⃣  Fix the failing tests"
  echo "  3️⃣  Run tests locally: npm test"
  echo "  4️⃣  Stage and commit again"
  echo ""
  echo "⚠️  To bypass this check (NOT RECOMMENDED):"
  echo "    git commit --no-verify"
  echo ""
  exit 1
fi
