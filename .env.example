# Environment Configuration Example
# Copy to .env and update with your values

# ===== DATABASE - SUPABASE POSTGRESQL =====
POSTGRESQL_CONNECTION_STRING=Host=YOUR_PROJECT.supabase.co;Port=5432;Database=postgres;User Id=postgres;Password=YOUR_PASSWORD_HERE;
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ===== SUPABASE STORAGE =====
SUPABASE_STORAGE_BUCKET_CHEF_IMAGES=chef-images
SUPABASE_STORAGE_BUCKET_MENU_ITEM_IMAGES=menu-item-images

# ===== FRONTEND =====
FRONTEND_PORT=80
NODE_ENV=production
VITE_API_BASE_URL=http://localhost:8080/api

# ===== BACKEND =====
BACKEND_PORT=8080
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:80

# ===== API CONFIGURATION =====
API_BASE_URL=http://localhost:8080/api
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ===== LOGGING =====
LOG_LEVEL=Information

# ===== FEATURE FLAGS =====
ENABLE_SWAGGER=true
ENABLE_HEALTH_CHECK=true
ENABLE_SUPABASE_AUTH=true
ENABLE_SUPABASE_STORAGE=true
ENABLE_SUPABASE_REALTIME=true
